# Database
DB_PATH=data/stock.db

# Data Acquisition
DATA_START_DATE=2020-01-01
FETCH_BATCH_DELAY=0.5
ENABLE_EASTMONEY_PATCH=1

# Technical Indicators
MA_PERIODS=[5,10,20,60]
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BB_PERIOD=20
BB_STD=2.0
ENABLED_INDICATORS=["ma","rsi","macd","bollinger"]

# AI / ML
PREDICTION_HORIZON=5
TRAIN_TEST_SPLIT=0.8
MODEL_DIR=data/models
RF_N_ESTIMATORS=200
RF_MAX_DEPTH=10

# Logging
LOG_LEVEL=INFO
LOG_ROTATION="10 MB"
LOG_RETENTION="7 days"
